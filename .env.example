# docgen-service internal auth — must match backend DOCGEN_API_KEY
# Generate with: openssl rand -base64 32
DOCGEN_API_KEY=change-me-docgen-internal-key

# Optional: max upload size for /parse in bytes (default 26214400 = 25MB)
# DOCGEN_MAX_UPLOAD_BYTES=26214400

# Set to production in deployed environments
ENVIRONMENT=development

LOG_LEVEL=INFO
